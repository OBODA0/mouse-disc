#!/bin/bash
# Launcher script for Mouse Disc

# Get the real script location (follow symlinks)
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    [[ $SCRIPT_SOURCE != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"

# Check if running from packaged directory or source
if [ -f "$SCRIPT_DIR/src/main.py" ]; then
    # Running from packaged directory
    exec python3 "$SCRIPT_DIR/src/main.py" "$@"
elif [ -f "$SCRIPT_DIR/main.py" ]; then
    # Running from source
    exec python3 "$SCRIPT_DIR/main.py" "$@"
else
    echo "Error: Cannot find main.py in $SCRIPT_DIR"
    exit 1
fi
